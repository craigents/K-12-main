# Go specific
###################
# Compiled executables
*.exe
*.exe~
*.dll
*.so
*.dylib
*.out

# Test binaries
*.test

# Output of the go coverage tool, specifically when run with the
# -o option
coverage.out

# Dependency directories (remove the comment below if you do not commit vendor)
# vendor/

# IDE settings and project files
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Backend specific binary name
backend/k12platform_backend
backend/k12platform_backend.exe


